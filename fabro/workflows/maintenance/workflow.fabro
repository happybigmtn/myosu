digraph MaintenanceWorkflow {
    graph [
        goal="Maintenance workflow: inspect recurring surface, refresh evidence, and publish reviewed operational artifacts."
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit [shape=Msquare, label="Exit"]

    inspect [label="Inspect"]
    update [label="Update evidence"]
    review [label="Review"]

    start -> inspect -> update -> review -> exit
}
