digraph ServicesWorkflow {
    graph [
        goal="Service workflow: define service contract, bring up binary surface, verify integration points, and capture reviewed artifacts."
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit [shape=Msquare, label="Exit"]

    contract [label="Contract"]
    bringup [label="Bringup"]
    verify [shape=parallelogram, label="Verify"]
    review [label="Review"]

    start -> contract -> bringup -> verify -> review -> exit
}
