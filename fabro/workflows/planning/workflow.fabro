digraph PlanningWorkflow {
    graph [
        goal="Planning workflow: gather context, map dependencies, and publish an implementation-ready plan."
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit [shape=Msquare, label="Exit"]

    research [label="Research"]
    map [label="Map dependencies"]
    publish [label="Publish plan"]

    start -> research -> map -> publish -> exit
}
