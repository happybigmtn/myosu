digraph ImplementWorkflow {
    graph [
        goal="Implementation workflow: specify scope, implement, verify behavior, and promote reviewed artifacts."
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit [shape=Msquare, label="Exit"]

    spec [label="Spec"]
    implement [label="Implement"]
    verify [shape=parallelogram, label="Verify"]
    promote [label="Promote"]

    start -> spec -> implement -> verify -> promote -> exit
}
