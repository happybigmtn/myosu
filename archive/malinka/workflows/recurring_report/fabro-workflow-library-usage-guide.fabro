digraph FabroWorkflowLibraryUsageGuide {
    graph [
        goal="Document workflow library with usage guide\n\nChild work item of plan: Complete Fabro Workflow Library\n\nObjective:\nCreate README mapping each lane type to its recommended workflow family with rationale\n\nOwned surfaces:\n- `fabro/workflows/README.md`\n\nProof commands:\n- `test -f fabro/workflows/README.md`\n- `rg -c '## ' fabro/workflows/README.md`\n\nRequired durable artifacts:\n- `spec.md`\n- `review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/recurring_report/fabro-workflow-library-usage-guide/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/recurring_report/fabro-workflow-library-usage-guide/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/recurring_report/fabro-workflow-library-usage-guide/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f fabro/workflows/README.md && rg -c '## ' fabro/workflows/README.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
