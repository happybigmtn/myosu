digraph GameEngineSdkDeveloperGuide {
    graph [
        goal="Write developer guide: 30-Minute Game\n\nChild work item of plan: Game Engine SDK Development\n\nObjective:\nProduce a step-by-step guide for implementing Kuhn Poker from scaffold to trait compliance pass\n\nOwned surfaces:\n- `crates/myosu-sdk/docs/30-minute-game.md`\n\nProof commands:\n- `test -f crates/myosu-sdk/docs/30-minute-game.md`\n\nRequired durable artifacts:\n- `spec.md`\n- `review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/recurring_report/game-engine-sdk-developer-guide/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/recurring_report/game-engine-sdk-developer-guide/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/recurring_report/game-engine-sdk-developer-guide/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f crates/myosu-sdk/docs/30-minute-game.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
