digraph TestCoverageSprint {
    graph [
        goal="Test Coverage Sprint\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `genesis/plans/001-master-plan.md`\n- `genesis/plans/002-fabro-cleanup-completion.md`\n\nCurrent frontier tasks:\n- Add screen transition tests to `myosu-tui`\n- Add shell state tests to `myosu-tui`\n- Add event loop tests to `myosu-tui`\n- Add property-based round-trip tests to `myosu-games`\n- Integrate into Fabro quality gates (proof commands must run these tests)\n\nRequired durable artifacts:\n- `outputs/test-coverage-sprint/spec.md`\n- `outputs/test-coverage-sprint/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/test-coverage-sprint/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/test-coverage-sprint/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/test-coverage-sprint/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/test-coverage-sprint/spec.md && test -f ./outputs/test-coverage-sprint/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
