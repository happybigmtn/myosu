+digraph ImplementMultiGame {
+    graph [
+        goal="Implement the next approved games:multi-game slice and produce durable implementation artifacts.",
+        model_stylesheet="
+            *       { backend: cli; }
+            #review { backend: api; model: gpt-5.4; provider: openai; }
+        "
+    ]
+    rankdir=LR
+
+    start [shape=Mdiamond, label="Start"]
+    exit  [shape=Msquare, label="Exit"]
+
+    preflight [label="Preflight", shape=parallelogram, script="./fabro/checks/games-multi-game-implement.sh 2>&1 || true", max_retries=0]
+    implement [label="Implement", prompt="@../../prompts/implement/games-multi-game-implement.md", reasoning_effort="high"]
+    fmt       [label="Format", shape=parallelogram, script="cargo fmt -p myosu-games-liars-dice -p myosu-games -p myosu-play -p myosu-tui 2>&1", max_retries=0]
+    verify    [label="Verify", shape=parallelogram, script="./fabro/checks/games-multi-game-implement.sh 2>&1", goal_gate=true, retry_target="fixup"]
+    fixup     [label="Fixup", prompt="@../../prompts/implement/games-multi-game-fix.md", reasoning_effort="high", max_visits=3]
+    review    [label="Review", prompt="@../../prompts/implement/games-multi-game-review.md", reasoning_effort="medium"]
+    audit     [label="Audit Artifacts", shape=parallelogram, script="test -f outputs/games/multi-game/implementation.md && test -f outputs/games/multi-game/verification.md && test -f outputs/games/multi-game/quality.md", goal_gate=true, max_retries=0]
+
+    start -> preflight -> implement -> fmt -> verify
+    verify -> review [condition="outcome=success"]
+    verify -> fixup
+    fixup -> fmt
+    review -> audit -> exit
+}
