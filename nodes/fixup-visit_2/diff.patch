+    title: TUI Shell Delivery
+    output_root: ../../outputs/tui/shell
+    artifacts:
+      - id: spec
+        path: spec.md
+      - id: review
+        path: review.md
+      - id: implementation
+        path: implementation.md
+      - id: verification
+        path: verification.md
+      - id: integration
+        path: integration.md
+    milestones:
+      - id: reviewed
+        requires: [spec, review]
+      - id: implemented
+        requires: [spec, review, implementation, integration]
+      - id: verified
+        requires: [spec, review, implementation, verification, integration]
+    lanes:
+      - id: shell-implement
+        kind: interface
+        title: Shell Implementation Lane
+        run_config: ../run-configs/implement/tui-shell.toml
+        managed_milestone: verified
+        proof_profile: tui_shell_implement
+        depends_on:
+          - unit: tui
+            milestone: reviewed
+        checks:
+          - label: tui_shell_code_present
+            kind: precondition
+            type: file_exists
+            path: ../../crates/myosu-tui/src/shell.rs
+          - label: tui_shell_implementation_proof
+            kind: proof
+            type: command_succeeds
+            command: ./fabro/checks/tui-shell-implement.sh
+        produces: [implementation, verification, integration]
