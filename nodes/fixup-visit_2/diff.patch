+digraph ImplementMultiGame {
+    graph [
+        goal="Implement the next approved `games:multi-game` slice.
+
+Inputs:
+- `multi-game/spec.md`
+- `multi-game/review.md`
+
+Scope:
+- work only inside the smallest next approved implementation slice
+- treat the reviewed lane artifacts as the source of truth
+- keep changes aligned with the owned surfaces for `games:multi-game`
+
+Required curated artifacts:
+- `multi-game/implementation.md`
+- `multi-game/verification.md`
+- `multi-game/quality.md`
+- `multi-game/promotion.md`",
+        model_stylesheet="
+            *       { backend: cli; }
+            #review { backend: api; model: gpt-5.4; provider: openai; }
+            #settle { backend: api; model: gpt-5.4; provider: openai; }
+        "
+    ]
+    rankdir=LR
+
+    start [shape=Mdiamond, label="Start"]
+    exit  [shape=Msquare, label="Exit"]
+
+    preflight [label="Preflight", shape=parallelogram, script="./fabro/checks/multi-game-slice1.sh 2>&1 || true", max_retries=0]
+    implement [label="Implement", prompt="@../../prompts/implement/multi-game/plan.md", reasoning_effort="high"]
+    verify    [label="Verify", shape=parallelogram, script="./fabro/checks/multi-game-slice1.sh 2>&1", goal_gate=true, retry_target="fixup"]
+    fixup     [label="Fixup", prompt="@../../prompts/implement/multi-game/polish.md", reasoning_effort="high", max_visits=3]
+    quality   [label="Quality Gate", shape=parallelogram, script="set -e\nQUALITY_PATH='outputs/games/multi-game/quality.md'\nIMPLEMENTATION_PATH='outputs/games/multi-game/implementation.md'\nVERIFICATION_PATH='outputs/games/multi-game/verification.md'\nplaceholder_hits=\"\"\nscan_placeholder() {\n  surface=\"$1\"\n  if [ ! -e \"$surface\" ]; then\n    return 0\n  fi\n  hits=\"$(rg -n -i -g '*.rs' -g 'Cargo.toml' -g '*.toml' 'TODO|stub|placeholder|future slice|not yet implemented|compile-only|for now|will implement' \"$surface\" || true)\"\n  if [ -n \"$hits\" ]; then\n    if [ -n \"$placeholder_hits\" ]; then\n      placeholder_hits=\"$(printf '%s\\n%s' \"$placeholder_hits\" \"$hits\")\"\n    else\n      placeholder_hits=\"$hits\"\n    fi\n  fi\n}\nscan_placeholder 'crates/myosu-games-liars-dice/Cargo.toml'\nartifact_hits=\"$(rg -n -i 'manual proof still required|future slice|compile-only|placeholder|stub implementation|not yet fully implemented' \"$IMPLEMENTATION_PATH\" \"$VERIFICATION_PATH\" 2>/dev/null || true)\"\nwarning_hits=\"$(rg -n 'warning:' \"$IMPLEMENTATION_PATH\" \"$VERIFICATION_PATH\" 2>/dev/null || true)\"\nmanual_hits=\"$(rg -n -i 'manual proof still required|manual;' \"$VERIFICATION_PATH\" 2>/dev/null || true)\"\nplaceholder_debt=no\nwarning_debt=no\nartifact_mismatch_risk=no\nmanual_followup_required=no\n[ -n \"$placeholder_hits\" ] && placeholder_debt=yes\n[ -n \"$warning_hits\" ] && warning_debt=yes\n[ -n \"$artifact_hits\" ] && artifact_mismatch_risk=yes\n[ -n \"$manual_hits\" ] && manual_followup_required=yes\nquality_ready=yes\nif [ \"$placeholder_debt\" = yes ] || [ \"$warning_debt\" = yes ] || [ \"$artifact_mismatch_risk\" = yes ] || [ \"$manual_followup_required\" = yes ]; then\n  quality_ready=no\nfi\nmkdir -p \"$(dirname \"$QUALITY_PATH\")\"\ncat > \"$QUALITY_PATH\" <<EOF\nquality_ready: $quality_ready\nplaceholder_debt: $placeholder_debt\nwarning_debt: $warning_debt\nartifact_mismatch_risk: $artifact_mismatch_risk\nmanual_followup_required: $manual_followup_required\n\n## Touched Surfaces\n- crates/myosu-games-liars-dice/Cargo.toml\n\n## Placeholder Hits\n$placeholder_hits\n\n## Artifact Consistency Hits\n$artifact_hits\n\n## Warning Hits\n$warning_hits\n\n## Manual Followup Hits\n$manual_hits\nEOF\ntest \"$quality_ready\" = yes", goal_gate=true, retry_target="fixup"]
+    settle    [label="Settle", prompt="@../../prompts/implement/multi-game/promote.md", reasoning_effort="high"]
+    audit     [label="Audit Artifacts", shape=parallelogram, script="test -f outputs/games/multi-game/implementation.md && test -f outputs/games/multi-game/verification.md && test -f outputs/games/multi-game/quality.md && test -f outputs/games/multi-game/promotion.md && test -f outputs/games/multi-game/integration.md && grep -Eq '^merge_ready: yes$' outputs/games/multi-game/promotion.md && grep -Eq '^manual_proof_pending: no$' outputs/games/multi-game/promotion.md && grep -Eq '^quality_ready: yes$' outputs/games/multi-game/quality.md && grep -Eq '^placeholder_debt: no$' outputs/games/multi-game/quality.md && grep -Eq '^warning_debt: no$' outputs/games/multi-game/quality.md && grep -Eq '^artifact_mismatch_risk: no$' outputs/games/multi-game/quality.md && grep -Eq '^manual_followup_required: no$' outputs/games/multi-game/quality.md", goal_gate=true, retry_target="fixup", max_retries=0]
+
+    start -> preflight -> implement -> verify
+    verify -> quality [condition="outcome=success"]
+    verify -> fixup
+    quality -> settle [condition="outcome=success"]
+    quality -> fixup
+    settle -> audit [condition="outcome=success"]
+    settle -> fixup
+    audit -> exit [condition="outcome=success"]
+    audit -> fixup
+    fixup -> verify
+}
