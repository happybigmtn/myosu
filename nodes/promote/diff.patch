+fn sdk_dependency_path(target_dir: &Path) -> Result<String, ScaffoldError> {
+    let sdk_dir = PathBuf::from(env!("CARGO_MANIFEST_DIR")).canonicalize()?;
+    let target_dir = target_dir.canonicalize()?;
