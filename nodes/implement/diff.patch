+
+    #[test]
+    fn clarify_returns_prompt_for_ambiguous() {
+        let renderer = NlheRenderer::preflop(1);
+        assert!(renderer.clarify("r").is_some());
+        assert!(renderer.clarify("raise").is_none());
+    }
+}
