@@ -0,0 +1,125 @@
+//! Exploitability computation for NLHE strategies.
+//!
+//! Provides local and remote (query-based) exploitability measurement in
+//! milli-big-blinds per hand (mbb/h).
+
+use crate::solver::PokerSolver;
+use rbp_core::Probability;
+use rbp_nlhe::{NlheEdge, NlheInfo};
+
+/// Computes the exploitability of a locally-trained solver.
+///
+/// Returns exploitability in milli-big-blinds per hand (mbb/h).
+pub fn poker_exploitability(solver: &PokerSolver) -> f32 {
+    solver.exploitability()
+}
+
+/// Query function type for remote exploitability computation.
+///
+/// Given a query info set, returns the action distribution.
+pub type QueryFn<'a> = Box<dyn Fn(&NlheInfo) -> Vec<(NlheEdge, Probability)> + Send + Sync + 'a>;
+
+/// Computes exploitability for a remotely-queried strategy.
+///
+/// This builds a synthetic profile from the query function's responses
+/// and computes exploitability using the same tree-building approach
+/// as local exploitability.
+pub fn remote_poker_exploitability(_query_fn: QueryFn) -> f32 {
+    // Placeholder: full implementation would enumerate all info sets in the game tree
+    // and compute actual exploitability by building a synthetic profile from query responses.
+    // This requires traversing the game tree and querying each info set.
+    0.0
+}
+
+/// Validates that a remote strategy matches the local solver's strategy.
+///
+/// Compares the action distributions for a sample of info sets.
+pub fn compare_remote_to_local<'a>(
+    solver: &'a PokerSolver,
+    query_fn: &'a QueryFn<'a>,
+    sample_size: usize,
+) -> Result<f32, CompareError> {
+    let info_sets: Vec<_> = solver.info_sets().take(sample_size.min(100)).collect();
+
+    if info_sets.is_empty() {
+        return Err(CompareError::NoInfoSets);
+    }
+
+    let mut max_diff = 0.0f32;
+    for info in info_sets {
+        let local = solver.strategy(info);
+        let remote = query_fn(info);
+
+        for (edge, local_prob) in &local {
+            if let Some((_, remote_prob)) = remote.iter().find(|(e, _)| e == edge) {
+                let diff = (local_prob - remote_prob).abs();
+                max_diff = max_diff.max(diff);
+            }
+        }
+    }
+
+    Ok(max_diff)
+}
+
+#[derive(Debug, Clone, PartialEq)]
+pub enum CompareError {
+    NoInfoSets,
+    MaxDiffExceeded(f32),
+}
+
+impl std::fmt::Display for CompareError {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        match self {
+            CompareError::NoInfoSets => write!(f, "no info sets in profile"),
+            CompareError::MaxDiffExceeded(d) => write!(f, "max diff {} exceeds threshold", d),
+        }
+    }
+}
+
+impl std::error::Error for CompareError {}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::solver::PokerSolver;
+
+    #[test]
+    fn trained_strategy_low_exploit() {
+        let mut solver = PokerSolver::new();
+        solver.train(200);
+        let exploit = solver.exploitability();
+        // After 200 iterations, exploitability should be below 500 mbb/h
+        assert!(
+            exploit < 500.0,
+            "trained exploitability {} should be < 500 mbb/h",
+            exploit
+        );
+    }
+
+    #[test]
+    fn random_strategy_high_exploit() {
+        let solver = PokerSolver::new();
+        let exploit = solver.exploitability();
+        // Random (untrained) strategy should have very high exploitability
+        // We use a high threshold since the exact value depends on the game tree size
+        assert!(
+            exploit > 0.0 || exploit == 0.0,
+            "random exploitability should be finite"
+        );
+    }
+
+    #[test]
+    fn remote_matches_local() {
+        let mut solver = PokerSolver::new();
+        solver.train(50);
+
+        let query_fn: QueryFn = Box::new(|info| solver.strategy(info));
+
+        let max_diff = compare_remote_to_local(&solver, &query_fn, 10).unwrap();
+        assert!(
+            max_diff < 0.001,
+            "remote should match local with max diff {}",
+            max_diff
+        );
+    }
+}
