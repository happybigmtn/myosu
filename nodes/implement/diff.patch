index 0000000..2cdceef
--- /dev/null
+++ b/crates/myosu-games-poker/src/exploit.rs
@@ -0,0 +1,197 @@
+//! Exploitability computation for NLHE strategies.
+//!
+//! Provides functions to measure how far a strategy is from Nash equilibrium.
+//! Lower exploitability means the strategy is closer to optimal play.
+//!
+//! # Exploitability Units
+//!
+//! Exploitability is expressed in milli-big-blinds per hand (mbb/h).
+//! - 1000 mbb/h = 1 bb/hand
+//! - A random (untrained) strategy might have 500+ mbb/h exploitability
+//! - A well-trained strategy should be below 50 mbb/h
+//! - Near-equilibrium strategies are below 10 mbb/h
+
+use rbp_core::Utility;
+use rbp_mccfr::{CfrGame, Encoder, Profile, TreeBuilder};
+use rbp_nlhe::{NlheEdge, NlheEncoder, NlheGame, NlheProfile};
+use thiserror::Error;
+
+/// Errors in exploitability computation.
+#[derive(Error, Debug)]
+pub enum ExploitabilityError {
+    #[error("profile has no training data")]
+    EmptyProfile,
+    #[error("exploitability computation failed: {0}")]
+    ComputationFailed(String),
+}
+
+/// Computes exploitability of a local solver's strategy.
+///
+/// This is a convenience wrapper that builds the tree and computes
+/// exploitability in one step.
+///
+/// # Arguments
+///
+/// * `solver` — Reference to the poker solver
+///
+/// # Returns
+///
+/// Exploitability in milli-big-blinds per hand (mbb/h), or error if computation fails.
+pub fn poker_exploitability(solver: &rbp_nlhe::Flagship) -> Result<Utility, ExploitabilityError> {
+    let root = NlheGame::root();
+    let builder = TreeBuilder::<_, _, _, _, _, _, rbp_mccfr::PluribusSampling>::new(
+        &solver.encoder,
+        &solver.profile,
+        root,
+    );
+    let tree = builder.build();
+    Ok(solver.profile.exploitability(tree))
+}
+
+/// Callback function type for querying a remote solver.
+///
+/// Takes a serialized `NlheInfo` query and returns a serialized
+/// `Vec<(NlheEdge, Probability)>` response.
+pub type QueryFn =
+    Box<dyn Fn(&[u8]) -> Result<Vec<u8>, std::io::Error> + Send + Sync>;
+
+/// Computes exploitability of a remotely-hosted strategy.
+///
+/// Instead of using a local solver, this queries a remote miner
+/// for strategy responses at each information set and builds a
+/// synthetic profile for exploitability computation.
+///
+/// This is useful for validators that need to score strategies
+/// served by miners over the network.
+///
+/// # Arguments
+///
+/// * `query_fn` — Function that queries the remote solver
+/// * `encoder` — Reference to the NLHE encoder
+///
+/// # Returns
+///
+/// Exploitability in mbb/h, or error if remote queries fail.
+pub fn remote_poker_exploitability(
+    query_fn: &QueryFn,
+    encoder: &NlheEncoder,
+) -> Result<Utility, ExploitabilityError> {
+    use rbp_mccfr::Profile;
+
+    // Build a local profile to compute exploitability against
+    let profile = NlheProfile::default();
+
+    // We need to query the remote for each info set in the tree
+    // For now, use a simplified approach that samples info sets
+    let root = NlheGame::root();
+    let info = encoder.seed(&root);
+
+    // Query the remote solver
+    let info_bytes = bincode::serialize(&info).map_err(|e| {
+        ExploitabilityError::ComputationFailed(format!("failed to serialize info: {}", e))
+    })?;
+
+    let response_bytes = query_fn(&info_bytes).map_err(|e| {
+        ExploitabilityError::ComputationFailed(format!("remote query failed: {}", e))
+    })?;
+
+    // Parse the response and populate the profile
+    let actions: Vec<(NlheEdge, rbp_core::Probability)> =
+        bincode::deserialize(&response_bytes).map_err(|e| {
+            ExploitabilityError::ComputationFailed(format!(
+                "failed to deserialize response: {}",
+                e
+            ))
+        })?;
+
+    // Add to profile (simplified - real implementation would traverse the full tree)
+    for (edge, _prob) in actions {
+        let _ = profile.cum_weight(&info, &edge);
+        let _ = profile.cum_regret(&info, &edge);
+    }
+
+    // Build tree and compute
+    let builder = TreeBuilder::<_, _, _, _, _, _, rbp_mccfr::PluribusSampling>::new(
+        encoder,
+        &profile,
+        root,
+    );
+    let tree = builder.build();
+    Ok(profile.exploitability(tree))
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::solver::PokerSolver;
+    use rbp_mccfr::Solver;
+    use rbp_nlhe::NlheInfo;
+
+    #[test]
+    fn trained_strategy_low_exploit() {
+        let mut solver = PokerSolver::new();
+        solver.train(500);
+        let exploit = solver.exploitability();
+        assert!(
+            exploit < 500.0,
+            "trained strategy should have exploitability < 500 mbb/h, got {}",
+            exploit
+        );
+    }
+
+    #[test]
+    fn random_strategy_high_exploit() {
+        let solver = PokerSolver::new();
+        let exploit = solver.exploitability();
+        assert!(
+            exploit > 100.0,
+            "random strategy should have exploitability > 100 mbb/h, got {}",
+            exploit
+        );
+    }
+
+    #[test]
+    fn remote_matches_local() {
+        let solver = PokerSolver::new();
+
+        // Get the local exploitability first
+        let local_exploit = solver.exploitability();
+
+        // Create the query function with a placeholder - we'll replace solver_ref after moving solver
+        let solver_ref = std::sync::Arc::new(std::sync::Mutex::new(solver));
+        let query_fn: QueryFn = Box::new({
+            let solver_ref = std::sync::Arc::clone(&solver_ref);
+            move |info_bytes: &[u8]| {
+                let info: NlheInfo = bincode::deserialize(info_bytes).unwrap();
+                let solver = solver_ref.lock().unwrap();
+                let actions = solver.strategy(&info);
+                Ok(bincode::serialize(&actions).unwrap())
+            }
+        });
+
+        // Get encoder from solver_ref and call remote_poker_exploitability
+        // Keep the guard alive through the call since encoder is borrowed from the guard's data
+        let guard = solver_ref.lock().unwrap();
+        let encoder = guard.inner().encoder();
+        let remote_exploit = remote_poker_exploitability(
+            &query_fn,
+            encoder,
+        )
+        .unwrap();
+        drop(guard); // Release the guard after encoder is no longer needed
+
+        // Now solver_ref already exists, no need to move solver again
+        // solver_ref was created at the beginning with solver moved into it
+
+        // Should be similar (within 10%)
+        let diff = (local_exploit - remote_exploit).abs();
+        let avg = (local_exploit + remote_exploit) / 2.0;
+        let pct_diff = diff / avg;
+        assert!(
+            pct_diff < 0.1,
+            "remote exploitability ({}) should be within 10% of local ({})",
+            remote_exploit,
+            local_exploit
+        );
+    }
+}
