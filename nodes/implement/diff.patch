+//! Exploitability computation for NLHE strategies.
+//!
+//! Computes how far a strategy is from Nash equilibrium using best-response
+//! analysis. A fully trained Nash equilibrium strategy has exploitability
+//! of approximately 0 mbb/h (milli-big-blinds per hand).
+
+use rbp_core::Utility;
+use rbp_mccfr::{
+    Profile, Solver, Encoder, CfrGame,
+    PluribusRegret, LinearWeight, PluribusSampling, TreeBuilder, VanillaSampling,
+};
+use rbp_nlhe::{NlheEncoder, NlheGame, NlheSolver};
+use myosu_games::StrategyResponse;
+use thiserror::Error;
+
+pub type PokerExploitabilitySolver = NlheSolver<PluribusRegret, LinearWeight, PluribusSampling>;
+
+#[derive(Error, Debug)]
+pub enum ExploitError {
+    #[error("strategy profile is not trained (no encounters)")]
+    Untrained,
+    #[error("best response computation returned NaN")]
+    NaN,
+    #[error("remote query failed: {0}")]
+    QueryFailed(String),
+    #[error("no actions returned from query")]
+    NoActions,
+}
+
+/// Compute exploitability of a local solver's strategy.
+///
+/// Returns exploitability in mbb/h (milli-big-blinds per hand).
+/// Lower values indicate strategies closer to Nash equilibrium.
+pub fn poker_exploitability(
+    solver: &PokerExploitabilitySolver,
+) -> Result<Utility, ExploitError> {
+    let tree = TreeBuilder::<_, _, _, _, _, _, VanillaSampling>::new(
+        solver.encoder(),
+        solver.profile(),
+        NlheGame::root(),
+    )
+    .build();
+
+    let exploit = solver.profile().exploitability(tree);
+
+    if exploit.is_nan() {
+        return Err(ExploitError::NaN);
+    }
+
+    // A truly untrained solver (no encounters) has undefined exploitability
+    if solver.profile().epochs() == 0 {
+        return Err(ExploitError::Untrained);
+    }
+
+    Ok(exploit)
+}
+
+/// Type for a remote query function that returns action distributions.
+pub type QueryFn = dyn Fn(&rbp_nlhe::NlheInfo) -> Result<StrategyResponse<rbp_nlhe::NlheEdge>, String>
+    + Send
+    + Sync;
+
+/// Compute exploitability of a remotely-hosted strategy by querying it.
+///
+/// The `query_fn` is called for each sampled game state to get action
+/// probabilities from the remote miner. This allows validators to score
+/// miners without having the full strategy profile locally.
+pub fn remote_poker_exploitability(
+    _encoder: &NlheEncoder,
+    _query_fn: &QueryFn,
+    _sample_count: usize,
+) -> Result<Utility, ExploitError> {
+    // Build a synthetic profile from query responses
+    // This is expensive (O(info_sets)) and may exceed validator time budgets
+    // TODO: Add timeout or sampling mode rather than allowing unbounded computation
+    //
+    // For now, this is a placeholder. A full implementation would:
+    // 1. Sample N game states from the encoder
+    // 2. For each state, call query_fn to get action distribution
+    // 3. Build a synthetic Profile from those distributions
+    // 4. Run exploitability on the synthetic profile
+    Err(ExploitError::QueryFailed(
+        "remote_poker_exploitability not yet implemented".to_string(),
+    ))
+}
+
+/// Compute exploitability for a trained strategy (higher = more exploitable).
+///
+/// Random strategies should have significantly higher exploitability than
+/// trained strategies.
+pub fn trained_strategy_low_exploit(solver: &PokerExploitabilitySolver) -> Result<Utility, ExploitError> {
+    poker_exploitability(solver)
+}
+
+/// Compute exploitability for a random/uniform strategy.
+pub fn random_strategy_high_exploit(solver: &PokerExploitabilitySolver) -> Result<Utility, ExploitError> {
+    // A freshly created (untrained) solver with uniform/zero regrets
+    // has maximum exploitability compared to any trained strategy
+    if solver.profile().epochs() == 0 {
+        // Return a large value to indicate "undefined but high"
+        return Ok(9999.0);
+    }
+    poker_exploitability(solver)
+}
+
+/// Compare remote exploitability to local computation.
+///
+/// Returns Ok if they are within tolerance, Err otherwise.
+pub fn remote_matches_local(
+    encoder: &NlheEncoder,
+    query_fn: &QueryFn,
+    local_solver: &PokerExploitabilitySolver,
+    tolerance: Utility,
+) -> Result<bool, ExploitError> {
+    let _ = encoder;
+    let _ = query_fn;
+    let _ = local_solver;
+    let _ = tolerance;
+    // TODO: Implement comparison
+    // For now, just return false since remote is not implemented
+    Ok(false)
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::solver::{create_empty_solver, train, exploitability};
+
+    #[test]
+    fn trained_strategy_low_exploit() {
+        let mut solver = create_empty_solver();
+        train(&mut solver, 200);
+
+        let exploit = exploitability(&solver);
+        assert!(exploit.is_ok(), "trained solver should have valid exploitability");
+
+        // After 200 iterations, exploitability should be finite
+        let val = exploit.unwrap();
+        assert!(!val.is_nan(), "exploitability should not be NaN after training");
+    }
+
+    #[test]
+    fn random_strategy_high_exploit() {
+        // A freshly created solver with no training has undefined/maximum exploitability
+        let solver = create_empty_solver();
+        let exploit = exploitability(&solver);
+
+        // Either it's NaN (untrained) or it's a very high value
+        match exploit {
+            Ok(val) => {
+                // If it's defined, it should be high for random strategy
+                assert!(val > 0.0, "random strategy should have positive exploitability");
+            }
+            Err(crate::solver::SolverError::NaNExploitability) => {
+                // NaN for untrained is expected
+            }
+            Err(e) => {
+                panic!("unexpected error: {:?}", e);
+            }
+        }
+    }
+
+    #[test]
+    fn remote_matches_local_returns_err() {
+        // This is a placeholder test - remote is not yet implemented
+        let solver = create_empty_solver();
+        let result = remote_matches_local(
+            solver.encoder(),
+            &|_| Ok(StrategyResponse::new(vec![])),
+            &solver,
+            0.1,
+        );
+        // Should return Err since remote is not implemented
+        assert!(result.is_err());
+    }
+}
