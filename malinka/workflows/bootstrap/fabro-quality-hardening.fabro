digraph FabroQualityHardening {
    graph [
        goal="Fabro Quality Hardening\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `genesis/plans/001-master-plan.md`\n- `genesis/plans/002-fabro-cleanup-completion.md`\n\nCurrent frontier tasks:\n- Audit all Fabro proof commands for false-green patterns\n- Replace `cargo test -p myosu-games` with explicit test names\n- Add quality gate to all implementation-family programs\n- Add smoke test to all generated programs\n- Verify autodev no longer produces compile-only completions\n\nRequired durable artifacts:\n- `outputs/fabro-quality-hardening/spec.md`\n- `outputs/fabro-quality-hardening/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/fabro-quality-hardening/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/fabro-quality-hardening/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/fabro-quality-hardening/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/fabro-quality-hardening/spec.md && test -f ./outputs/fabro-quality-hardening/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
