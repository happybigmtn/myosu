digraph AgentExperience {
    graph [
        goal="Agent Experience Implementation\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `genesis/plans/001-master-plan.md`\n- `genesis/plans/002-fabro-cleanup-completion.md`\n\nCurrent frontier tasks:\n- Implement agent memory system (per-agent persistent memory)\n- Implement reflection prompt (`reflect>`)\n- Implement journal (append-only markdown autobiography)\n- Implement identity persistence\n- Implement rich narration mode (`--narrate`)\n- Verify agent experience across multiple Fabro lane runs\n\nRequired durable artifacts:\n- `outputs/agent-experience/spec.md`\n- `outputs/agent-experience/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/agent-experience/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/agent-experience/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/agent-experience/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/agent-experience/spec.md && test -f ./outputs/agent-experience/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
