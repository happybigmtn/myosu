digraph CiCdPipelineAddCheckAndTest {
    graph [
        goal="Add cargo check and cargo test for active crates\n\nChild work item of plan: CI/CD Pipeline Setup\n\nObjective:\nAdd CI steps that run cargo check and cargo test against myosu-games and myosu-tui crates\n\nOwned surfaces:\n- `.github/workflows/ci.yml`\n\nProof commands:\n- `cargo check -p myosu-games -p myosu-tui`\n- `cargo test -p myosu-games -p myosu-tui`\n\nRequired durable artifacts:\n- `spec.md`\n- `review.md`",
        model_stylesheet="
            *            { backend: cli; }
            #challenge   { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #review      { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #deep_review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #escalation  { backend: cli; model: claude-opus-4-6; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    preflight [label="Preflight", shape=parallelogram, script="set +e\ncargo check -p myosu-games -p myosu-tui && cargo test -p myosu-games -p myosu-tui\ntrue", max_retries=0]
    implement [label="Implement", prompt="@../../prompts/implementation/ci-cd-pipeline-add-check-and-test/plan.md", reasoning_effort="high"]
    verify [label="Verify", shape=parallelogram, script="cargo check -p myosu-games -p myosu-tui && cargo test -p myosu-games -p myosu-tui", goal_gate=true, retry_target="fixup"]
    quality [label="Quality Gate", shape=parallelogram, script="set -e\nQUALITY_PATH='quality.md'\nIMPLEMENTATION_PATH='outputs/ci-cd-pipeline-add-check-and-test/implementation.md'\nVERIFICATION_PATH='outputs/ci-cd-pipeline-add-check-and-test/verification.md'\nplaceholder_hits=\"\"\nscan_placeholder() {\n  surface=\"$1\"\n  if [ ! -e \"$surface\" ]; then\n    return 0\n  fi\n  if [ -f \"$surface\" ]; then\n    surface=\"$(dirname \"$surface\")\"\n  fi\n  hits=\"$(rg -n -i -g '*.rs' -g '*.py' -g '*.js' -g '*.ts' -g '*.tsx' -g '*.md' -g 'Cargo.toml' -g '*.toml' 'TODO|stub|placeholder|not yet implemented|compile-only|for now|will implement|todo!|unimplemented!' \"$surface\" || true)\"\n  if [ -n \"$hits\" ]; then\n    if [ -n \"$placeholder_hits\" ]; then\n      placeholder_hits=\"$(printf '%s\\n%s' \"$placeholder_hits\" \"$hits\")\"\n    else\n      placeholder_hits=\"$hits\"\n    fi\n  fi\n}\ntrue\nartifact_hits=\"$(rg -n -i 'manual proof still required|placeholder|stub implementation|not yet fully implemented|todo!|unimplemented!' \"$IMPLEMENTATION_PATH\" \"$VERIFICATION_PATH\" 2>/dev/null || true)\"\nwarning_hits=\"$(rg -n 'warning:' \"$IMPLEMENTATION_PATH\" \"$VERIFICATION_PATH\" 2>/dev/null || true)\"\nmanual_hits=\"$(rg -n -i 'manual proof still required|manual;' \"$VERIFICATION_PATH\" 2>/dev/null || true)\"\nplaceholder_debt=no\nwarning_debt=no\nartifact_mismatch_risk=no\nmanual_followup_required=no\n[ -n \"$placeholder_hits\" ] && placeholder_debt=yes\n[ -n \"$warning_hits\" ] && warning_debt=yes\n[ -n \"$artifact_hits\" ] && artifact_mismatch_risk=yes\n[ -n \"$manual_hits\" ] && manual_followup_required=yes\nquality_ready=yes\nif [ \"$placeholder_debt\" = yes ] || [ \"$warning_debt\" = yes ] || [ \"$artifact_mismatch_risk\" = yes ] || [ \"$manual_followup_required\" = yes ]; then\n  quality_ready=no\nfi\nmkdir -p \"$(dirname \"$QUALITY_PATH\")\"\ncat > \"$QUALITY_PATH\" <<EOF\nquality_ready: $quality_ready\nplaceholder_debt: $placeholder_debt\nwarning_debt: $warning_debt\nartifact_mismatch_risk: $artifact_mismatch_risk\nmanual_followup_required: $manual_followup_required\n\n## Touched Surfaces\n- (none declared)\n\n## Placeholder Hits\n$placeholder_hits\n\n## Artifact Consistency Hits\n$artifact_hits\n\n## Warning Hits\n$warning_hits\n\n## Manual Followup Hits\n$manual_hits\nEOF\ntest \"$quality_ready\" = yes", goal_gate=true, retry_target="fixup"]
    fixup [label="Fixup", prompt="@../../prompts/implementation/ci-cd-pipeline-add-check-and-test/polish.md", reasoning_effort="high", max_visits=3]
    challenge [label="Challenge", prompt="@../../prompts/implementation/ci-cd-pipeline-add-check-and-test/challenge.md", reasoning_effort="medium"]
    review [label="Review", prompt="@../../prompts/implementation/ci-cd-pipeline-add-check-and-test/review.md", reasoning_effort="high"]
    audit [label="Audit Artifacts", shape=parallelogram, script="test -f outputs/ci-cd-pipeline-add-check-and-test/spec.md && test -f outputs/ci-cd-pipeline-add-check-and-test/review.md && grep -Eq '^merge_ready: yes$' promotion.md && grep -Eq '^manual_proof_pending: no$' promotion.md && grep -Eq '^reason: .+$' promotion.md && grep -Eq '^next_action: .+$' promotion.md", goal_gate=true, retry_target="fixup", max_retries=0]

    start -> preflight -> implement -> verify
    verify -> quality [condition="outcome=success"]
    verify -> fixup
    quality -> challenge [condition="outcome=success"]
    quality -> fixup
    challenge -> review [condition="outcome=success"]
    challenge -> fixup
    review -> audit [condition="outcome=success"]
    review -> fixup
    audit -> exit [condition="outcome=success"]
    audit -> fixup
    fixup -> verify
}
