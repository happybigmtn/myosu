digraph RaspberryProgramDecomposition {
    graph [
        goal="Complete Raspberry Program Decomposition\n\nBootstrap the first service slice and establish a deterministic health surface.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `genesis/plans/001-master-plan.md`\n- `genesis/plans/002-fabro-cleanup-completion.md`\n\nCurrent frontier tasks:\n- Harden dependency edges — explicit ordering of which program must complete before which\n- Verify `myosu.yaml` (parent portfolio) correctly dispatches all 6 child programs\n- Stress-test autodev loop with all 6 programs active\n\nRequired durable artifacts:\n- `outputs/raspberry-program-decomposition/spec.md`\n- `outputs/raspberry-program-decomposition/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    inventory [label="Inventory", prompt="@../../prompts/service_bootstrap/raspberry-program-decomposition/plan.md", reasoning_effort="high"]
    review    [label="Review", prompt="@../../prompts/service_bootstrap/raspberry-program-decomposition/review.md", reasoning_effort="high"]
    polish    [label="Polish", prompt="@../../prompts/service_bootstrap/raspberry-program-decomposition/polish.md", reasoning_effort="medium"]
    verify_outputs [label="Verify Outputs", shape=parallelogram, script="test -f ./outputs/raspberry-program-decomposition/spec.md && test -f ./outputs/raspberry-program-decomposition/review.md", goal_gate=true, max_retries=0]

    start -> inventory -> review -> polish -> verify_outputs -> exit
}
