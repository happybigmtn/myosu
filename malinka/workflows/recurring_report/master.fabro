digraph Master {
    graph [
        goal="180-Day Myosu Turnaround Master Plan\n\nProduce the recurring report artifact for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `genesis/plans/001-master-plan.md`\n- `genesis/plans/002-fabro-cleanup-completion.md`\n\nRequired durable artifacts:\n- `outputs/master/report.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/recurring_report/master/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/recurring_report/master/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/recurring_report/master/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/master/report.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
